algoritmo "livraria"
// O valor unitï¿½rio de um livro na promoï¿½ï¿½o custa R$ 12,00, caso o cliente comprar atï¿½ dez livros. Caso contrï¿½rio,
// O preï¿½o unitï¿½rio do livro custa R$ 8,00. Escreva um algoritmo que leia o nï¿½mero de livros comprados, calcule e mostre o valor total que o cliente deverï¿½ pagar.
var livrosComprados, valor, precoUnitario: inteiro

inicio
    // Pede ao usuï¿½rio a quantidade de livros comprados
    Escreva("Insira quantos livros foram comprados: ")
    Leia(livrosComprados)

    // Verifica quantos livros foram comprados e altera a variï¿½vel precoUnitario
    se (livrosComprados < 10) entao
    precoUnitario <- 12
    senao
    precoUnitario <- 8
    fimse
    
    // Calcula o valor total a pagar e mostra na tela
    valor <- precoUnitario * livrosComprados
    Escreva("O valor dos livros serï¿½ de R$", valor)
fimalgoritmo
