algoritmo "multiplo3"
// 1. Elabore um algoritmo que leia um nïŋ―mero e imprima uma das mensagens: ïŋ―
// mïŋ―ltiplo de 3, ou, nïŋ―o ïŋ― mïŋ―ltiplo de 3.
var numero: inteiro

inicio
    escreva("Insira um nïŋ―mero qualquer, inteiro: ")
    leia(numero)
    
    se (numero % 3 = 0) entao
    escreva("Mïŋ―ltiplo de 3")
    senao
    escreva("Nïŋ―o ïŋ― mïŋ―ltiplo de 3")
    fimse
fimalgoritmo
