algoritmo "trocaDeValores"
// Escreva um algoritmo que leia um valor para a variï¿½vel A e um valor para a variï¿½vel B.
// Logo apï¿½s, o algoritmo deverï¿½ fazer com que a variï¿½vel A guarde o valor da variï¿½vel B e a variï¿½vel B guarde o valor da variï¿½vel A.
// Apresentar os valores das variï¿½veis A e B antes e depois da troca.
var A, B, C: inteiro

inicio
    Escreva("Digite o valor de A: ")
    Leia(A)
    
    Escreva("Digite o valor de B: ")
    Leia(B)
    
    Escreval("------- ANTES DAS TROCAS DE VALORES -------")
    Escreval("A: ", A)
    Escreval("B: ", B)
    
    C <- A
    A <- B
    B <- C
    
    Escreval("------- DEPOIS DAS TROCAS DE VALORES -------")
    Escreval("A: ", A)
    Escreval("B: ", B)
fimalgoritmo
