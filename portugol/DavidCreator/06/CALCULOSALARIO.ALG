algoritmo "calculoSalario"
// Faï¿½a um algoritmo que leia o valor que um funcionï¿½rio ganha por hora e o nï¿½mero de horas trabalhadas no mï¿½s. Calcule e mostre o total do seu salï¿½rio no referido mï¿½s.
var ganhoHora, salario: real
    horasTrabalhadas: inteiro

inicio
    // Pede o ganho por hora
    Escreva("Quanto vocï¿½ ganha por hora? R$")
    Leia(ganhoHora)
    
    // Pede horas trabalhadas
    Escreva("Quantas horas trabalha por dia? ")
    Leia(horasTrabalhadas)
    
    // Calcula e exibe o salï¿½rio
    salario <- (ganhoHora * horasTrabalhadas) * 30
    Escreva("Seu salï¿½rio ï¿½ de R$", salario)
fimalgoritmo
