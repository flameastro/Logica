algoritmo "premioNatacao"
// Em uma competiï¿½ï¿½o o nadador ï¿½ premiado de acordo com a distï¿½ncia mï¿½xima que percorrer.
//Se o nadador percorrer uma distï¿½ncia menor que 800 metros, recebe R$ 5.000,00 reais de prï¿½mio
//Caso percorra uma distï¿½ncia entre 800 e 1500 metros, recebe R$ 10.000,00
//E se percorrer uma distï¿½ncia superior a 1500 metros, recebe R$ 15.000,00 em prï¿½mio.
//Escreva um algoritmo que leia a distï¿½ncia percorrida e mostre na tela o valor da premiaï¿½ï¿½o a ser recebida pelo nadador.
var distancia, premio: inteiro

inicio
    // Pede a distï¿½ncia em metros
    Escreva("DISTï¿½NCIA QUE O NADADOR PERCORREU EM METROS: ")
    Leia(distancia)
    
    // Atribui o premio na variï¿½vel premio de acordo com a distï¿½ncia percorrida
    se (distancia < 800) entao
    premio <- 5000
    senao
    se (distancia >= 800) e (distancia <= 1500) entao
    premio <- 10000
    senao
    se (distancia > 1500) entao
     premio <- 15000
    fimse
    fimse
    fimse
    
    // Mostra o prï¿½mio do nadador
    Escreva("O PRï¿½MIO SERï¿½ DE R$", premio)
fimalgoritmo
