algoritmo "somaNumeros"
// Escreva um algoritmo que leia dez valores numï¿½ricos inteiros e apresente na tela o somatï¿½rio dos valores.
var contador, valor, soma: inteiro

inicio
    // Declara a variï¿½vel soma como 0
    soma <- 0

    // Conta de 1 atï¿½ 10
    Para contador <- 1 ate 10 faca
    // Pede ao usuï¿½rio o valor atual
    Escreva("DIGITE O VALOR ", contador, ": ")
    Leia(valor)
    
    // Guarda na variï¿½vel soma o valor inserido
    soma <- soma + valor
    fimpara
    
    // Exibe a soma dos nï¿½meros
    Escreva("A soma dos nï¿½meros inseridos ï¿½ de ", soma)
fimalgoritmo
