algoritmo "somaNumeros"
// Elabore um algoritmo que leia dois nïŋ―meros e mostre a soma deles.
var numero1, numero2, soma: inteiro

inicio
    Escreva("Nïŋ―MERO 1: ")
    Leia(numero1)
    
    Escreva("Nïŋ―MERO 2: ")
    Leia(numero2)
    
    soma <- numero1 + numero2
    Escreva("A soma ïŋ― ", soma)
fimalgoritmo
