algoritmo "metadeNumero"
// Elabore um algoritmo que leia um nïŋ―mero, e se ele for maior do que 20, imprimir
// a metade desse nïŋ―mero.
var numero: inteiro

inicio
    escreva("Insira qualquer nïŋ―mero: ")
    leia(numero)
    
    se (numero > 20) entao
    escreva(numero / 2)
    senao
    escreva(numero)
    fimse
fimalgoritmo
