algoritmo "positivoQuadradoMetade"
// Elabore um algoritmo que leia um nï¿½mero e, se ele for positivo, imprima a metade
// desse nï¿½mero, caso contrï¿½rio imprima o nï¿½mero ao quadrado.
var numero: inteiro

inicio
    escreva("Insire um nï¿½mero: ")
    leia(numero)
    
    se (numero % 2 = 0) entao
    escreva(numero / 2)
    senao
    escreva(numero ^ 2)
    fimse
fimalgoritmo
