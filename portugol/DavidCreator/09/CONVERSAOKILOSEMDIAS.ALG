algoritmo "conversaoKilosEmDias"
// Desenvolva um algoritmo que receba uma quantidade de um alimento em quilos, calcule e mostre quantos dias durarï¿½ esse alimento para uma pessoa que consome 50 gramas desse alimento por dia.
var pessoaCome, dias: inteiro
    quantidadeAlimento, quantidadeAlimentoGramas: real

inicio
    // Variï¿½veis iniciais
    pessoaCome <- 50
    dias <- 0

    // Pede ao usuï¿½rio a quantidade de alimentos em quilos e guarda na variï¿½vel
    Escreva("Insira a quantidade de alimentos em quilos: ")
    Leia(quantidadeAlimento)

    // Calcula e guarda a quantidade de alimentos em gramas
    quantidadeAlimentoGramas <- quantidadeAlimento * 1000
    
    // Realiza a lï¿½gica para saber quantos dias durarï¿½
    enquanto quantidadeAlimentoGramas >= pessoaCome faca
    pessoaCome <- pessoaCome + 50
    dias <- dias + 1
    fimenquanto
    
    // Mostra as informaï¿½ï¿½es
    Escreva("O alimento durarï¿½ ", dias, " dias para uma pessoa que consome 50 gramas por dia")
fimalgoritmo
