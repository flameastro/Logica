algoritmo "lanchoneteBauru"
//Uma lancheria estï¿½ com alguns problemas para atender aos pedidos dos clientes.
//Nï¿½o vai ser possï¿½vel atender pedidos que tenham algumas combinaï¿½ï¿½es do cardï¿½pio, sï¿½o elas:

//a) O lanche bauru nï¿½o poderï¿½ ser acompanhado da bebida guaranï¿½.
//b) Se o cliente pedir X galinha, nï¿½o poderï¿½ pedir ï¿½gua.
//c) Quando o cliente pedir Pizza, somente poderï¿½ beber vinho ou ï¿½gua.
//Dessa forma, elabore um algoritmo que leia o lanche e a bebida e verifique se o pedido poderï¿½ ser ou nï¿½o atendido.
var opcao: inteiro
    lancheBauru, guarana, xGalinha, agua, pizza, vinho, podePedir: logico

inicio
    // Variï¿½veis
    podePedir <- Verdadeiro

    lancheBauru <- Falso
    xGalinha <- Falso
    pizza <- Falso
    agua <- Falso
    guarana <- Falso
    vinho <- Falso

    Escreval("----------------------------------------")
    Escreval("    L A N C H O N E T E    B A U R U    ")
    Escreval("----------------------------------------")

    Escreval("    C    A    R    D    ï¿½    P    I    O - COMIDA")
    Escreval("[1]: LANCHE BAURU")
    Escreval("[2]: X GALINHA")
    Escreval("[3]: PIZZA")
    Escreval("----------------------------------------")

    Escreva("Seleciona a opï¿½ï¿½o desejada para a comida: ")
    Leia(opcao)

    se (opcao = 1) entao
    lancheBauru <- Verdadeiro
    senao
    se (opcao = 2) entao
    xGalinha <- Verdadeiro
    senao
    se (opcao = 3) entao
     pizza <- Verdadeiro
    fimse
    fimse
    fimse
    
    Escreval("    C    A    R    D    ï¿½    P    I    O - ACOMPANHAMENTO")
    Escreval("[1]: GUARANï¿½")
    Escreval("[2]: ï¿½GUA")
    Escreval("[3]: VINHO")
    Escreval("----------------------------------------")
    
    Escreva("Seleciona a opï¿½ï¿½o desejada para o acompanhamento: ")
    Leia(opcao)
    
    se (opcao = 1) entao
    guarana <- Verdadeiro
    senao
    se (opcao = 2) entao
    agua <- Verdadeiro
    senao
    se (opcao = 3) entao
     vinho <- Verdadeiro
    fimse
    fimse
    fimse
    
    // Situaï¿½ï¿½o A [O lanche bauru nï¿½o poderï¿½ ser acompanhado da bebida guaranï¿½]
    se (lancheBauru = Verdadeiro) e (guarana = Verdadeiro) entao
    podePedir <- Falso
    fimse
    
    // Situaï¿½ï¿½o B [Se o cliente pedir X galinha, nï¿½o poderï¿½ pedir ï¿½gua]
    se (xGalinha = Verdadeiro) e (agua = Verdadeiro) entao
    podePedir <- Falso
    fimse
    
    // Situaï¿½ï¿½o C [Quando o cliente pedir Pizza, somente poderï¿½ beber vinho ou ï¿½gua]
    se (pizza = Verdadeiro) e (guarana = Verdadeiro) entao
    podePedir <- Falso
    fimse

    LimpaTela
    
    Escreval("--------------------------------")
    Escreval("    R    E    S    U    L    T    A    D    O    S    ")
    se (podePedir = Verdadeiro) entao
    Escreval("    O PEDIDO PODE SER FEITO!")
    senao
    Escreval("    O PEDIDO Nï¿½O PODE SER FEITO")
    fimse
    Escreval("--------------------------------")
fimalgoritmo
