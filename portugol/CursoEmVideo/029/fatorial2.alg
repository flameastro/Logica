algoritmo "fatorial"
// Entendendo o que ï¿½ fatorial
// !5 = 5 x 4 x 3 x 2 x 1
// 5 x 4 = 20 x 3 = 60 x 2 = 120 x 1 = 120

var contador, numero, resultado: inteiro
    resposta: caractere

inicio
    Repita
    // Variï¿½veis necessï¿½rias
    resultado <- 1
    contador <- 0

    // Pede ao usuÃ¡rio o nï¿½mero desejado e guarda na variï¿½vel numero
    Escreva("Por favor, insira o nï¿½mero que deseja saber o fatorial: ")
    Leia(numero)

    Repita // A cada repetiï¿½ï¿½o...
     resultado <- resultado * numero // O resultado multiplica ele mesmo pelo nï¿½mero atual - que decrementa a cada repetiï¿½ï¿½o
     numero <- numero - 1 // O nï¿½mero decrementa
     contador <- contador + 1 // O contador decrementa
    Ate (numero < 1) // Repete atï¿½ o nï¿½mero for menor que 1 (0)

    Escreval("O fatorial de ", contador, " ï¿½ ", resultado)
    
    Escreva("Deseja continuar? [S/N]: ")
    Leia(resposta)
    Ate ((resposta = "N") ou (resposta = "n"))
fimalgoritmo
