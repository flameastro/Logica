algoritmo "tabelaDeValores"
// Escrever um algoritmo que lï¿½ um valor numï¿½rico inteiro. Apï¿½s, escreva uma tabela com cabeï¿½alho, contendo o valor, seu quadrado e seu cubo. Mostrar para todos valores entre o valor informado e 1.
// Por exemplo, digamos que o nï¿½mero informado seja 20, deve-se apresentar na tela:

//Nï¿½mero    Dobro    Triplo
//20    400    8000
//19    361    6859
//18    324    5832
var numero: inteiro

inicio
    // Pede ao usuï¿½rio o nï¿½mero
    Escreva("Nï¿½MERO: ")
    Leia(numero)
    
    LimpaTela
    
    Escreval("-----------------------------")
    Escreval("Nï¿½mero    Dobro    Triplo")

    // Enquanto numero for maior que 0
    enquanto numero > 0 faca
    // Exibe o nï¿½mero, o dobro, e o triplo
    Escreval(numero, "    ", numero^2, "    ", numero^3)
    numero <- numero - 1
    fimenquanto
    
    Escreval("-----------------------------")
fimalgoritmo
