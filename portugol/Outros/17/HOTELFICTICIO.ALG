algoritmo "HotelFicticio"
// Faï¿½a um programa para calcular a conta final de um hï¿½spede de um hotel fictï¿½cio,
//considerando que:
// Devem ser lidos o nome do hï¿½spede, o tipo do apartamento utilizado (A, B,
//C ou D), o nï¿½mero de diï¿½rias utilizadas pelo hï¿½spede e o valor do consumo
//interno do hï¿½spede;
// O valor da diï¿½ria ï¿½ determinado pela seguinte tabela:
//TIPO DO APTO ï¿½ VALOR DA DIï¿½RIA (R$)
//A ï¿½ 150.00
//B ï¿½ 100.00
//C ï¿½ 75.00
//D ï¿½ 150.00
//Escreva a conta final contendo: o nome do hï¿½spede, o tipo do apartamento, o
//nï¿½mero de diï¿½rias utilizadas, o valor unitï¿½rio da diï¿½ria, o valor total das diï¿½rias
var nome, tipoApartamento: caractere
    numeroDiarias, valorDiaria, valorTotal: inteiro

inicio
    escreva("Insira o seu nome: ")
    leia(nome)
    
    escreva("Tipo de apartamento [A/B/C/D]: ")
    leia(tipoApartamento)
    
    se (tipoApartamento = "A") ou (tipoApartamento = "D") entao
    valorDiaria <- 150
    senao
    se (tipoApartamento = "B") entao
    valorDiaria <- 100
    senao
    se (tipoApartamento = "C") entao
     valorDiaria <- 75
    fimse
    fimse
    fimse
    
    escreva("Nï¿½mero de diï¿½rias: ")
    leia(numeroDiarias)
    
    valorTotal <- valorDiaria * numeroDiarias

    escreval("-------------------------")
    escreval("NOME: ", nome)
    escreval("TIPO DE APARTAMENTO: ", tipoApartamento)
    escreval("Nï¿½MERO DE DIï¿½RIAS: ", numeroDiarias)
    escreval("VALOR DE CADA DIï¿½RIA: ", valorDiaria)
    escreval("VALOR TOTAL: ", valorTotal)
    escreval("-------------------------")
fimalgoritmo
