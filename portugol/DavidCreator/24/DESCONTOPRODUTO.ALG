algoritmo "descontoProduto"
// Elabore um algoritmo que tendo como entrada o preï¿½o e cï¿½digo de origem de um produto,
// Cï¿½lcule e mostre na tela o valor do desconto concedido. Os cï¿½digos sï¿½o os seguintes:
// regiï¿½o norte com desconto de 5%,
// regiï¿½o sul com desconto de 15%,
// regiï¿½o sudeste com desconto de 7%,
// regiï¿½o nordeste com desconto de 12% e
// regiï¿½o centro-oeste com desconto de 20%.
// Caso nï¿½o seja informado nenhum cï¿½digo vï¿½lido informar na tela que o produto ï¿½ importado
var preco, desconto: real
    codigo: inteiro
    importado: logico

inicio
    // Declara importado como Falso
    importado <- Falso
    
    Escreval("----------------------------------------")
    Escreval("    D E S C O N T O    DE    P R O D U T O    ")
    Escreval("----------------------------------------")

    // Pede o preï¿½o do produto
    Escreva("PREï¿½O DO PRODUTO: ")
    Leia(preco)
    
    // Mostra os cï¿½digos
    Escreval("--------------- Cï¿½DIGOS DE ORIGEM ---------------")
    Escreval("[1]: Regiï¿½o Norte") // desconto <- 5%
    Escreval("[2]: Regiï¿½o Su1") // desconto <- 15%
    Escreval("[3]: Regiï¿½o Sudeste") // desconto <- 7%
    Escreval("[4]: Regiï¿½o Nordeste") // desconto <- 12%
    Escreval("[5]: Regiï¿½o Centro-Oeste") // desconto <- 20%
    Escreval("[OUTRO Nï¿½MERO]: Fora do Brasil")
    Escreva("DIGITE O Cï¿½DIGO DE ORIGEM: ")
    Leia(codigo)
    
    // Calcula o desconto baseado no cï¿½digo inserido
    se (codigo = 1) entao
    desconto <- 5
    senao
    se (codigo = 2) entao
    desconto <- 15
    senao
    se (codigo = 3) entao
     desconto <- 7
    senao
     se (codigo = 4) entao
    desconto <- 12
     senao
    se (codigo = 5) entao
     desconto <- 20
    senao
     importado <- Verdadeiro
    fimse
     fimse
    fimse
    fimse
    fimse
    
    // Calcula o preo de acordo com o desconto
    preco <- preco - (preco * (desconto / 100))
    
    LimpaTela

    // Mostra os resultados
    Escreval("----------    R    E    S    U    L    T    A    D    O    S    ----------")

    se (importado) entao
    Escreva("O produto foi importado e continua sem desconto: R$", preco)
    senao
    Escreval("Vocï¿½ recebeu ", desconto, "% de desconto")
    Escreval("O preï¿½o do produto ï¿½ de R$", preco)
    fimse

    Escreva("-----------------------------------------------------")
fimalgoritmo
